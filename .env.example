PORT=3000
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Aiven MySQL (free 5GB tier)
# Get these from: console.aiven.io → your MySQL service → Overview tab
DB_HOST=mysql-xxxx-xxxx.aivencloud.com
DB_PORT=19306
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password
DB_NAME=defaultdb

# Set to 1 when deploying on Vercel
VERCEL=1
