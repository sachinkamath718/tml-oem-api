      "name": "1. Generate Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "const accessToken = response.access_token;",
              "pm.collectionVariables.set(\"access-token\", accessToken);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "type": "text",
              "key": "client_id",
              "value": "{{client-id}}"
            },
            {
              "type": "text",
              "key": "client_secret",
              "value": "{{client-secret}}"
            },
            {
              "type": "text",
              "key": "grant_type",
              "value": "client_credentials"
            }
          ]
        },
        "url": {
          "raw": "{{cvp-base-url}}/auth/realms/cvp/protocol/openid-connect/token",
          "host": [
            "{{cvp-base-url}}"
          ],
          "path": [
            "auth",
            "realms",
            "cvp",
            "protocol",
            "openid-connect",
            "token"
          ]
        }
      },
      "response": []
